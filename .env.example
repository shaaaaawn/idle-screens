# Copy to repo-root .env and fill in real values. Never commit .env.
# Used by apps/mac/scripts/* for local sign + notarize + GitHub secret setup.

APPLE_ID=you@example.com
APPLE_TEAM_ID=XXXXXXXXXX
APPLE_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx
P12_PASSWORD=choose-a-strong-export-password

# One-time CSR generation (generate-csr.sh)
# CSR_ORG=Your Org, LLC

# Optional overrides
# DEVELOPER_ID=Developer ID Application: Your Org (TEAMID)
# NOTARY_PROFILE=idle-notary
# DEVELOPER_ID_CER=/path/to/downloaded.cer
