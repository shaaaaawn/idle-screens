{
  "name": "idle-screens",
  "author": "Shawn Partridge",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "description": "An off-main-thread, capability-tiered, agent-operable screensaver engine for the modern web.",
  "license": "MIT",
  "repository": { "type": "git", "url": "https://github.com/shaaaaawn/idle-screens" },
  "homepage": "https://github.com/shaaaaawn/idle-screens#readme",
  "packageManager": "pnpm@9.15.9",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "pnpm -r --filter \"./packages/*\" run build",
    "typecheck": "pnpm -r run typecheck",
    "lint": "eslint .",
    "test": "vitest run",
    "test:e2e": "pnpm --filter @idle-screens/playground run test:e2e",
    "test:all": "pnpm build && pnpm typecheck && pnpm lint && pnpm test && pnpm test:e2e",
    "dev": "pnpm --filter @idle-screens/playground run dev",
    "changeset": "changeset"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.11",
    "@playwright/test": "^1.49.1",
    "@types/node": "^22.10.2",
    "eslint": "^9.17.0",
    "happy-dom": "^20.10.6",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.1",
    "vite": "^6.0.5",
    "vitest": "^2.1.8"
  }
}
