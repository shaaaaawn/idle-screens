{
  "name": "@idle-screens/savers-classic",
  "version": "2.0.1",
  "description": "Classic screensavers for idle-screens (toasters, DVD, warp, rain, and more), ported to framework-agnostic saver plugins.",
  "license": "MIT",
  "author": "Shawn Partridge",
  "repository": {
    "type": "git",
    "url": "https://github.com/shaaaaawn/idle-screens",
    "directory": "packages/savers-classic"
  },
  "homepage": "https://github.com/shaaaaawn/idle-screens#readme",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./worker": {
      "types": "./dist/idle-worker.d.ts",
      "import": "./dist/idle-worker.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "screensaver",
    "idle",
    "ambient",
    "after-dark",
    "canvas",
    "toasters",
    "dvd"
  ],
  "bugs": {
    "url": "https://github.com/shaaaaawn/idle-screens/issues"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src"
  },
  "peerDependencies": {
    "@idle-screens/core": "workspace:*"
  },
  "devDependencies": {
    "@idle-screens/core": "workspace:*",
    "@idle-screens/schema": "workspace:*",
    "@webgpu/types": "^0.1.71"
  }
}
